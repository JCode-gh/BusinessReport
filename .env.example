# Server
NODE_ENV=development
PORT=3000
APP_BASE_URL=http://localhost:5173

# OpenRouter
OPEN_ROUTER_API_KEY=your_openrouter_api_key_here
OPEN_ROUTER_HTTP_REFERER=http://localhost:5173
OPEN_ROUTER_X_TITLE=AI Entrepreneur Growth Kit
OPEN_ROUTER_MODEL=openrouter/free
OPEN_ROUTER_MAX_COMPLETION_TOKENS=9000
OPEN_ROUTER_USE_JSON_SCHEMA=false

# Business kit generation
# BUSINESS_KIT_MODEL=your_paid_openrouter_model_here
BUSINESS_KIT_MAX_COMPLETION_TOKENS=9000
BUSINESS_KIT_USE_JSON_SCHEMA=false

# Stripe paywall
STRIPE_PAYWALL_ENABLED=false
STRIPE_FORCE_PAYWALL=false
STRIPE_SECRET_KEY=sk_test_your_stripe_secret_key_here
STRIPE_PRICE_ID=price_your_one_time_report_price
STRIPE_AMOUNT_LABEL=One-time report access
