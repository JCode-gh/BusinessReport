# Pollinations AI
VITE_POLLINATIONS_API_KEY=
# VITE_POLLINATIONS_MODEL=openai
# VITE_POLLINATIONS_MAX_TOKENS=8000

# Analytics (optional, recommended) — cookieless Plausible, no consent banner needed.
# Create a site at https://plausible.io, then set the domain below and redeploy.
# Funnel goals tracked as custom events: wizard_opened, report_generated,
# paywall_shown, checkout_started, payment_success.
# Leave empty to disable analytics entirely (no script loads).
VITE_PLAUSIBLE_DOMAIN=
# VITE_PLAUSIBLE_SRC=https://plausible.io/js/script.tagged-events.js

# Stripe — create an account at https://dashboard.stripe.com
# STRIPE_SECRET_KEY: Settings → API keys → Secret key (sk_live_... or sk_test_...)
# STRIPE_WEBHOOK_SECRET: Webhooks → Add endpoint → Signing secret (whsec_...)
#   Endpoint URL: https://growthkit.jcode.be/.netlify/functions/stripe-webhook
#   Event: checkout.session.completed
# STRIPE_PAYMENT_METHODS: comma-separated Checkout methods (must be enabled in live Stripe).
#   Default: card,bancontact — add ideal after enabling it at dashboard.stripe.com/account/payments/settings
STRIPE_SECRET_KEY=
STRIPE_PAYMENT_METHODS=card,bancontact
STRIPE_WEBHOOK_SECRET=

# Firebase Admin (for Netlify Functions) — Firebase Console → Project settings → Service accounts → Generate new private key
# Copy the JSON values here. FIREBASE_PRIVATE_KEY must include the full -----BEGIN PRIVATE KEY----- block.
FIREBASE_PROJECT_ID=
FIREBASE_CLIENT_EMAIL=
FIREBASE_PRIVATE_KEY=

# Firebase — create a project at https://console.firebase.google.com
# Enable Firestore + Auth (Google provider + Email/Password)
# These VITE_* values are public client config (embedded in the browser bundle).
# In Netlify, set them as normal env vars — do NOT flag them as "Contains secret values".
VITE_FIREBASE_API_KEY=
VITE_FIREBASE_AUTH_DOMAIN=
VITE_FIREBASE_PROJECT_ID=
VITE_FIREBASE_STORAGE_BUCKET=
VITE_FIREBASE_MESSAGING_SENDER_ID=
VITE_FIREBASE_APP_ID=
