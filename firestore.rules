rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {

    // Reports: only the owner can read/write
    match /reports/{reportId} {
      allow read, write: if request.auth != null && request.auth.uid == resource.data.uid;
      allow create: if request.auth != null && request.auth.uid == request.resource.data.uid;
    }

    // Users: owner can read their own document
    // Credits can only be decreased by the client (never increased — that happens via Firebase Admin in the webhook)
    match /users/{userId} {
      allow read: if request.auth != null && request.auth.uid == userId;
      allow update: if request.auth != null
        && request.auth.uid == userId
        && request.resource.data.credits < resource.data.credits
        && request.resource.data.credits >= 0;
    }
  }
}
